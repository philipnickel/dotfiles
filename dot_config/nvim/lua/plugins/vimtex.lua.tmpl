-- VimTeX config
return {
  {
    "lervag/vimtex",
    ft = "tex",
    config = function()
      -- Viewer: zathura_simple (recommended for macOS, see :h vimtex-faq-zathura-macos)
      -- Synctex requires dbus on macOS (brew install dbus; brew services start dbus)
      vim.g.vimtex_view_method = "zathura_simple"

      -- Compiler: latexmk with lualatex
      vim.g.vimtex_compiler_latexmk = {
        executable = "latexmk",
        options = {
          "-verbose",
          "-file-line-error",
          "-synctex=1",
          "-interaction=nonstopmode",
        },
      }
      vim.g.vimtex_compiler_latexmk_engines = {
        _ = "-lualatex",
      }

      -- Disable quickfix auto-open
      vim.g.vimtex_quickfix_mode = 0

      -- Disable folding (performance)
      vim.g.vimtex_fold_enabled = 0

      -- Disable conceal (performance)
      vim.g.vimtex_syntax_conceal_disable = 1

      -- Don't override K
      vim.g.vimtex_mappings_disable = { n = { "K" } }

      -- Spell checking for .tex files
      vim.api.nvim_create_autocmd("FileType", {
        pattern = "tex",
        callback = function()
          vim.opt_local.spell = true
          vim.opt_local.spelllang = "en_us"
        end,
      })
    end,
  },
}
